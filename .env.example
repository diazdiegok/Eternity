# Postgres (local: Docker/Neon/Render External URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/eternity?sslmode=require"

# Contraseña del panel admin (¡cambiala!)
ADMIN_PASSWORD="admin123"
ADMIN_SECRET="una-clave-secreta-larga-y-aleatoria"

# Autenticador TOTP (Microsoft Authenticator). Generar con: npm run totp:setup
# ADMIN_TOTP_SECRET="..."

# URL pública del sitio (necesaria para Mercado Pago en producción)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Mercado Pago (opcional). Sacá el token en https://www.mercadopago.com.ar/developers
# MP_ACCESS_TOKEN="APP_USR-..."
# MP_SANDBOX="true"

# Producción en Render:
# DATABASE_URL = Internal Database URL del Postgres Free (mismo dashboard)
