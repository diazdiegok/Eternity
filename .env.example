# Postgres (local: Docker/Neon/Render External URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/eternity?sslmode=require"

# Contraseña del panel admin (¡cambiala!)
ADMIN_PASSWORD="admin123"
ADMIN_SECRET="una-clave-secreta-larga-y-aleatoria"

# Autenticador TOTP (Microsoft Authenticator). Generar con: npm run totp:setup
# ADMIN_TOTP_SECRET="..."

# URL pública del sitio
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Mercado Pago (opcional)
# MP_ACCESS_TOKEN="APP_USR-..."
# MP_SANDBOX="true"

# Correos — Render Free BLOQUEA Gmail SMTP (puertos 587/465).
# Usá Resend (HTTPS): https://resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxx"
# Para pruebas sin dominio propio:
EMAIL_FROM="Eternity Recuerdos <onboarding@resend.dev>"
# Cuando verifiques un dominio en Resend:
# EMAIL_FROM="Eternity Recuerdos <pedidos@tudominio.com>"
# Respuestas del cliente pueden ir a tu Gmail:
# SMTP_USER="eternityjoyasmaternas@gmail.com"
